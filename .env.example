# ============================================================================
# kommo-cnn — .env.example (stack: GitHub + Vercel + Supabase)
# ----------------------------------------------------------------------------
# COPIE para .env e preencha.  cp .env.example .env
# O .env (preenchido) está no .gitignore — NUNCA suba. Config pública já vem preenchida.
# ============================================================================

# ─────────────────────────── VERCEL (hospeda a lógica) ─────────────────────
VERCEL_TOKEN=                        # Account → Settings → Tokens
VERCEL_ORG_ID=                       # preenchido pelo `vercel link` (.vercel/project.json)
VERCEL_PROJECT_ID=                   # preenchido pelo `vercel link`

# ─────────────────────────── GITHUB (repo + deploy contínuo) ───────────────
GITHUB_TOKEN=                        # PAT escopo repo

# ─────────────────────────── SUPABASE (banco + cron) ───────────────────────
SUPABASE_ACCESS_TOKEN=               # Account → Access Tokens (CLI/Management API)
SUPABASE_PROJECT_REF=
SUPABASE_URL=                        # https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
# POOLER (Supavisor) transaction mode :6543 — queries das Vercel Functions (prepare:false):
# postgres://postgres.<ref>:<senha>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=
# DIRECT :5432 — só migrations:
# postgres://postgres.<ref>:<senha>@db.<ref>.supabase.co:5432/postgres
DIRECT_URL=

# ─────────────────────────── CNN (Clínica nas Nuvens) ──────────────────────
CNN_CID=
CNN_BASIC_USER=
CNN_BASIC_PASS=
CNN_CID_PRODUCTION=
CNN_BASIC_USER_PRODUCTION=
CNN_BASIC_PASS_PRODUCTION=

# ─────────────────────────── Kommo (CRM) ───────────────────────────────────
KOMMO_SUBDOMAIN=atendimentoclinicabergmanncombr
KOMMO_ACCESS_TOKEN=
KOMMO_CLIENT_SECRET=

# ─────────────────────────── App (comportamento) ───────────────────────────
WEBHOOK_SECRET=
CNN_WRITE_TARGET=production
WH1_ENABLED=1
WH2_ENABLED=1

# ─────────────────────────── Cloudflare (LEGADO / migração de dados) ────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=4be8e1b3bbf4d7074f665e77fd6dca2d
